---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="企业官网">
  <div class="page-container">
    <Navbar />

    <section class="banner">
      <div class="decor-top-left"></div>
      <div class="decor-bottom-right"></div>

      <div class="banner-content">
        <div class="tag">2026 数字化领航者</div>
        <h1 class="banner-title">
          为未来企业构建<br />全栈数字引擎
        </h1>
        <p class="banner-desc">
          我们结合前沿技术研发能力与全球交付网络，为全球客户提供从战略咨询到交付落地的一站式数字化解决方案，驱动业务跨越式增长。
        </p>
        <div class="banner-buttons">
          <button class="btn-primary">获取转型白皮书 →</button>
          <button class="btn-outline">了解我们的实力</button>
        </div>
      </div>

      <div class="hex-group">
        <div class="hex hex-1"></div>
        <div class="hex hex-2"></div>
        <div class="hex hex-3"></div>
      </div>
    </section>

    <!-- 能力展示模块 -->
    <section class="capability-section">
      <!-- 三个椭圆背景（我帮你加在这里，不影响你的原有结构） -->
      <div class="ellipse-1"></div>
      <div class="ellipse-2"></div>
      <div class="ellipse-3"></div>

      <div class="capability-container">
        <div class="capability-left">
          <h2 class="capability-title">全域覆盖的能力保障，<br>赋能业务核心价值。</h2>
          <p class="capability-desc">
            极智数科（UltraDigit）在数字化转型领域建立了全球化的交付体系。我们通过分布在全国及海外的数十个分支机构，为金融、制造、政务等核心领域的中大型企业提供持续、稳定的技术支撑与创新动力。
          </p>
          <div class="capability-stats">
            <div class="stat-item">
              <span class="stat-number">40+</span>
              <span class="stat-label">分支机构覆盖</span>
            </div>
            <div class="stat-item">
              <span class="stat-number">3000+</span>
              <span class="stat-label">专业技术团队</span>
            </div>
          </div>
        </div>

        <div class="capability-right">
          <div class="capability-card">
            <div class="card-header">
              <div class="header-icon"></div>
              <h3>卓越的项目交付能力</h3>
            </div>
            <ul class="card-list">
              <li class="card-item">
                <div class="item-icon"></div>
                <div class="item-content">
                  <h4>极致标准化流程</h4>
                  <p>遵循 CMMI5 认证标准，端到端全链路数字化监控交付质量。</p>
                </div>
              </li>
              <li class="card-item">
                <div class="item-icon"></div>
                <div class="item-content">
                  <h4>全球离岸交付网络</h4>
                  <p>分布全球的交付中心，支持多时区无缝协同研发与运维。</p>
                </div>
              </li>
              <li class="card-item">
                <div class="item-icon"></div>
                <div class="item-content">
                  <h4>零缺陷安全管控</h4>
                  <p>内置安全开发生命周期（SDL），为金融级业务保驾护航。</p>
                </div>
              </li>
            </ul>
          </div>
        </div>
      </div>

      <button class="scroll-top-btn" aria-label="回到顶部">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M18 15l-6-6-6 6"/>
        </svg>
      </button>
    </section>

    <!-- 国内业务覆盖模块 -->
    <section class="coverage-section">
      <div class="coverage-container">
        <h2 class="coverage-title">国内业务覆盖能力</h2>
        <p class="coverage-subtitle">全国范围的资源调配与交付保障，助力客户实现跨区域业务协同。</p>

        <div class="coverage-content">
          <!-- 左侧蓝色标签栏 -->
          <div class="coverage-left">
            <div class="tag-item">
              <h3>40+ 分子机构覆盖</h3>
              <p>深厚的属地化服务网络</p>
            </div>
            <div class="tag-item">
              <h3>100+ 资深 PM 支撑</h3>
              <p>专家级项目管理与把控</p>
            </div>
            <div class="tag-item">
              <h3>广泛二三线城市覆盖</h3>
              <p>下沉市场的敏捷交付能力</p>
            </div>
            <div class="tag-item">
              <h3>全国覆盖的招聘能力</h3>
              <p>高效的人才库与供给体系</p>
            </div>
            <div class="tag-item">
              <h3>全品类岗位服务能力</h3>
              <p>覆盖全生命周期的岗位供给</p>
            </div>
          </div>

          <!-- 中间分公司列表 -->
          <div class="coverage-middle">
            <div class="branch-card">
              <div class="branch-header">
                <div class="branch-icon"></div>
                <h3>全国分子公司</h3>
              </div>
              <ul class="branch-list">
                <li>极智数科（北京）分公司</li>
                <li>极智数科（广州）分公司</li>
                <li>极智数科（深圳）分公司</li>
                <li>极智数科（杭州）分公司</li>
                <li>极智数科（南京）分公司</li>
                <li>极智数科（成都）分公司</li>
              </ul>
            </div>
          </div>

          <!-- 右侧地图图标 -->
          <div class="coverage-right">
            <div class="map-icon"></div>
          </div>
        </div>
      </div>
    </section>

    <!-- 全链路技术服务体系模块 -->
    <section class="service-section">
      <div class="service-container">
        <div class="service-header">
          <div class="header-text">
            <h2 class="service-title">全链路技术服务体系</h2>
            <p class="service-desc">
              从战略到技术，从基础设施到上层应用，我们提供闭环的数字化支撑，降低企业转型门槛。
            </p>
          </div>
          <button class="download-btn">下载服务目录</button>
        </div>

        <div class="service-list">
          <div class="service-item">
            <span class="item-number">01</span>
            <h3 class="item-title">数字化咨询</h3>
            <p class="item-desc">
              顶层架构设计、业务流程重组规划、技术选型建议及数字化路线图制定。
            </p>
          </div>
          <div class="service-item">
            <span class="item-number">02</span>
            <h3 class="item-title">定制化软件研发</h3>
            <p class="item-desc">
              基于微服务的敏捷开发、APP/小程序开发、高性能后端系统及跨端交互设计。
            </p>
          </div>
          <div class="service-item">
            <span class="item-number">03</span>
            <h3 class="item-title">云与基础设施</h3>
            <p class="item-desc">
              混合云迁移、DevOps体系建立、云原生容器化改造及网络安全加固。
            </p>
          </div>
          <div class="service-item">
            <span class="item-number">04</span>
            <h3 class="item-title">AI与大数据分析</h3>
            <p class="item-desc">
              数据湖建设、生成式AI模型训练、智能客服及自动化业务流程工具（RPA）。
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- 企业介绍模块 -->
    <section class="about-section">
      <div class="about-container">
        <!-- 左侧图片区域 -->
        <div class="about-image-area">
          <div class="image-wrapper">
            <img src="https://images.unsplash.com/photo-1497366216548-37526070297c?ixlib=rb-4.0.3&auto=format&fit=crop&w=1200&q=80" alt="极智数科办公环境" />
            <!-- 悬浮数据卡片 -->
            <div class="stats-card">
              <div class="stat-item">
                <span class="stat-number">8,500+</span>
                <span class="stat-label">全球员工</span>
              </div>
              <div class="stat-divider"></div>
              <div class="stat-item">
                <span class="stat-number">24</span>
                <span class="stat-label">全球交付中心</span>
              </div>
            </div>
          </div>
        </div>

        <!-- 右侧内容区域 -->
        <div class="about-content-area">
          <h2 class="slogan">
            "以极致技术，<br>创造智能世界。"
          </h2>
          <p class="desc">
            极智数科始终坚持以人才为核心，汇聚了来自全球顶尖科技公司的资深架构师与算法专家。我们不仅提供代码，更提供思想与变革的动力。2026年，我们正式启动了"AI+行业"战略，致力于将最前沿的通用人工智能技术普惠到每一个企业级场景中。
          </p>

          <!-- 企业使命/愿景 -->
          <div class="feature-list">
            <div class="feature-item">
              <div class="feature-icon mission-icon"></div>
              <div class="feature-content">
                <h4>企业使命</h4>
                <p>通过数字化创新，让复杂的业务变得简单高效。</p>
              </div>
            </div>
            <div class="feature-item">
              <div class="feature-icon vision-icon"></div>
              <div class="feature-content">
                <h4>企业愿景</h4>
                <p>成为全球领先的数字化转型战略合作伙伴。</p>
              </div>
            </div>
          </div>

          <button class="action-btn">了解发展历程</button>
        </div>
      </div>
    </section>

    <!-- 成功案例/客户展示模块 -->
    <section class="cases-section">
      <div class="cases-container">
        <div class="cases-header">
          <h2 class="cases-title">信任，源于成功的合作</h2>
          <p class="cases-subtitle">已帮助 500+ 家企业在数字浪潮中脱颖而出</p>
        </div>

        <div class="clients-logo">
          <div class="logo-item">
            <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/8/8c/Huawei_Logo.svg/1200px-Huawei_Logo.svg.png" alt="华为" />
          </div>
          <div class="logo-item empty"></div>
          <div class="logo-item empty"></div>
          <div class="logo-item">
            <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/5/51/Baidu_Logo_2019.svg/1200px-Baidu_Logo_2019.svg.png" alt="百度" />
          </div>
          <div class="logo-item">
            <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/4/4c/Bytedance_Logo.svg/1200px-Bytedance_Logo.svg.png" alt="字节跳动" />
          </div>
          <div class="logo-item">
            <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/4/4c/Mi_Logo_%282021%29.svg/1200px-Mi_Logo_%282021%29.svg.png" alt="小米" />
          </div>
        </div>

        <div class="cases-cards">
          <div class="case-card">
            <img src="https://images.unsplash.com/photo-1551434870-4982ac40429c?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" alt="金融行业案例" />
            <div class="case-meta">金融行业</div>
            <h3 class="case-title">某国有大行全量上云与分布式架构转型</h3>
            <p class="case-desc">
              通过极智数科自研的 Cloud-Link 工具包，帮助客户在 12 个月内平稳完成 2000+ 微服务单元的上云改造，系统可用性提升至 99.999%。
            </p>
            <a href="#" class="case-link">阅读完整案例 →</a>
          </div>

          <div class="case-card">
            <img src="https://images.unsplash.com/photo-1535224206242-484f62e1e14c?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" alt="智能制造案例" />
            <div class="case-meta">智能制造</div>
            <h3 class="case-title">世界500强制制造企业 AI 视觉质检系统</h3>
            <p class="case-desc">
              基于深度学习边缘计算，将生产线质检准确率由 85% 提升至 99.7%，每年为企业节省人力成本及物料损失超过 5000 万人民币。
            </p>
            <a href="#" class="case-link">阅读完整案例 →</a>
          </div>
        </div>
      </div>
    </section>

    <Footer />
  </div>
</Layout>

<style>
  /* 全局样式 */
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  }

  body {
    background: #f9f9f9;
  }

  /* 页面容器 */
  .page-container {
    width: 100%;
    min-height: 100vh;
    position: relative;
    overflow: hidden;
  }

  /* Banner */
  .banner {
    width: 100%;
    min-height: calc(100vh - 80px);
    display: flex;
    align-items: center;
    padding: 0 12%;
    position: relative;
    z-index: 5;
  }

  /* 装饰 */
  .decor-top-left {
    position: absolute;
    top: 0;
    left: 0;
    width: 200px;
    height: 200px;
    border-radius: 0 0 200px 0;
    background: linear-gradient(180deg, #e0e0f8 0%, #e0e0f8 50%, #3a4ed5 50%, #3a4ed5 100%);
    z-index: 0;
  }

  .decor-bottom-right {
    position: absolute;
    bottom: 0;
    right: 0;
    width: 200px;
    height: 200px;
    border-radius: 200px 0 0 0;
    background: #e0e0f8;
    z-index: 0;
  }

  /* 内容 */
  .banner-content {
    max-width: 600px;
    z-index: 6;
  }

  .tag {
    display: inline-block;
    padding: 4px 12px;
    background: #e0e7ff;
    color: #3a4ed5;
    border-radius: 12px;
    font-size: 14px;
    font-weight: 600;
    margin-bottom: 16px;
  }

  .tag::before {
    content: "●";
    margin-right: 6px;
    color: #3a78f5;
  }

  .banner-title {
    font-size: 64px;
    font-weight: 700;
    color: #1a23d5;
    line-height: 1.2;
    margin-bottom: 32px;
  }

  .banner-desc {
    font-size: 18px;
    color: #666;
    line-height: 1.8;
    margin-bottom: 40px;
  }

  .banner-buttons {
    display: flex;
    gap: 16px;
  }

  .btn-primary {
    padding: 16px 36px;
    background: #3a78f5;
    color: #fff;
    border: none;
    border-radius: 8px;
    font-size: 18px;
    font-weight: 600;
    cursor: pointer;
  }

  .btn-outline {
    padding: 16px 36px;
    background: transparent;
    color: #666;
    border: 1px solid #666;
    border-radius: 8px;
    font-size: 18px;
    cursor: pointer;
  }

  /* 六边形 */
  .hex-group {
    position: absolute;
    right: 15%;
    top: 50%;
    transform: translateY(-50%);
    z-index: 4;
  }

  .hex {
    width: 160px;
    height: 92.38px;
    background: #4a88f5;
    position: relative;
    margin: 30px 0;
    clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);
  }

  .hex::before {
    content: "";
    position: absolute;
    top: 8px;
    left: 8px;
    right: 8px;
    bottom: 8px;
    background: #f9f9f9;
    clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);
  }

  .hex-1 { margin-left: 40px; }
  .hex-2 { margin-left: 120px; }
  .hex-3 { margin-left: 40px; }

  /* 响应式 */
  @media (max-width: 1200px) {
    .banner-title {
      font-size: 48px;
    }
  }

  @media (max-width: 768px) {
    .banner {
      padding: 0 5%;
    }
    .banner-title {
      font-size: 36px;
    }
    .hex-group {
      display: none;
    }
  }

  /* ========== 能力展示模块样式 ========== */
  .capability-section {
    width: 100%;
    padding: 100px 12%;
    background: #0a1028;
    position: relative;
    overflow: hidden;
    box-sizing: border-box;
  }

  /* 🔥 椭圆 1（最大，包裹全部内容） */
  .ellipse-1 {
    position: absolute;
    width: 130%;
    height: 130%;
    top: -15%;
    left: -15%;
    background: rgba(50, 65, 180, 0.08);
    border-radius: 50%;
    z-index: 1;
    pointer-events: none;
  }

  /* 🔥 椭圆 2（中层） */
  .ellipse-2 {
    position: absolute;
    width: 100%;
    height: 100%;
    top: 0%;
    left: 0%;
    background: rgba(50, 65, 180, 0.12);
    border-radius: 50%;
    z-index: 1;
    pointer-events: none;
  }

  /* 🔥 椭圆 3（内层） */
  .ellipse-3 {
    position: absolute;
    width: 75%;
    height: 75%;
    top: 12%;
    left: 12%;
    background: rgba(50, 65, 180, 0.16);
    border-radius: 50%;
    z-index: 1;
    pointer-events: none;
  }

  /* ========== 布局 ========== */
  .capability-container {
    max-width: 1300px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    gap: 60px;
    position: relative;
    z-index: 2; /* 内容在椭圆上方 */
  }

  .capability-left {
    flex: 1;
    max-width: 580px;
  }

  .capability-right {
    flex: 1;
    max-width: 520px;
  }

  /* ========== 左侧文字 ========== */
  .capability-title {
    font-size: 42px;
    font-weight: 700;
    color: #fff;
    line-height: 1.3;
    margin-bottom: 24px;
  }

  .capability-desc {
    font-size: 17px;
    color: #c2c7d6;
    line-height: 1.8;
    margin-bottom: 36px;
  }

  .capability-stats {
    display: flex;
    gap: 70px;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .stat-number {
    font-size: 44px;
    font-weight: 700;
    color: #4a6fff;
  }

  .stat-label {
    font-size: 16px;
    color: #c2c7d6;
  }

  /* ========== 右侧卡片 ========== */
  .capability-card {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 20px;
    padding: 36px;
    backdrop-filter: blur(10px);
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 32px;
  }

  .header-icon {
    width: 40px;
    height: 40px;
    background: rgba(74, 111, 255, 0.15);
    border-radius: 50%;
    position: relative;
  }

  .header-icon::after {
    content: "✓";
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    color: #4a6fff;
    font-size: 18px;
    font-weight: bold;
  }

  .card-header h3 {
    font-size: 24px;
    color: #fff;
    margin: 0;
  }

  /* ========== 卡片列表 ========== */
  .card-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 28px;
  }

  .card-item {
    display: flex;
    gap: 18px;
  }

  .item-icon {
    width: 10px;
    height: 10px;
    background: #4a6fff;
    border-radius: 50%;
    margin-top: 8px;
    flex-shrink: 0;
  }

  .item-content h4 {
    font-size: 18px;
    color: #fff;
    margin: 0 0 6px 0;
  }

  .item-content p {
    font-size: 15px;
    color: #aab2c7;
    line-height: 1.6;
    margin: 0;
  }

  /* ========== 回到顶部按钮 ========== */
  .scroll-top-btn {
    position: fixed;
    right: 40px;
    bottom: 40px;
    width: 50px;
    height: 50px;
    border-radius: 50%;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.2);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 99;
  }

  /* 国内业务覆盖模块样式 */
  .coverage-section {
    width: 100%;
    min-height: 600px;
    background: #f9f9f9;
    padding: 80px 12%;
    display: flex;
    align-items: center;
  }

  .coverage-container {
    width: 100%;
    max-width: 1400px;
    margin: 0 auto;
  }

  .coverage-title {
    font-size: 36px;
    font-weight: 700;
    color: #111827;
    text-align: center;
    margin-bottom: 16px;
  }

  .coverage-subtitle {
    font-size: 16px;
    color: #6b7280;
    text-align: center;
    margin-bottom: 48px;
  }

