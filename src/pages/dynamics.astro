---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="企业动态 - 企业官网">
  <div class="page-container">
    <Navbar />

    <!-- 企业动态模块 -->
    <section class="dynamics-section" id="enterprise-dynamics">
      <div class="dynamics-container">
        <!-- 头部 -->
        <div class="dynamics-header">
          <div class="header-left">
            <h2 class="dynamics-title">企业动态 <span class="title-en">Corporate Dynamics</span></h2>
            <p class="dynamics-desc">紧贴前沿技术，实时共享极致科技的每一步成长与创新。</p>
          </div>
          <a href="#" class="view-all-link">
            <span>查看全部动态</span>
            <span class="arrow-icon">›</span>
          </a>
        </div>

        <!-- 动态卡片网格 -->
        <div class="dynamics-grid">
          <!-- 动态卡片 1 -->
          <div class="dynamics-card card-blue">
            <div class="card-image-wrapper">
              <img src="https://images.unsplash.com/photo-1550751827-4bd374c3f58b?auto=format&fit=crop&q=80&w=800" alt="Tech Event" class="card-image" />
              <div class="image-overlay"></div>
              <div class="card-tag tag-blue">技术发布</div>
            </div>
            <div class="card-content">
              <p class="card-date date-blue">2026年04月05日</p>
              <h3 class="card-title">昆仑时代正式发布 2.0 版"星脉"分布式调度引擎</h3>
              <p class="card-text">新版本引入了基于量子纠缠理论改进的共识算法，大幅提升了在超大规模异构网络下的同步效率。</p>
              <div class="card-footer">
                <div class="view-count">
                  <span class="eye-icon">👁</span>
                  <span>1.2k 阅读</span>
                </div>
                <span class="share-icon">⤴</span>
              </div>
            </div>
          </div>

          <!-- 动态卡片 2 -->
          <div class="dynamics-card card-cyan">
            <div class="card-image-wrapper">
              <img src="https://images.unsplash.com/photo-1517245386807-bb43f82c33c4?auto=format&fit=crop&q=80&w=800" alt="Collaboration" class="card-image" />
              <div class="image-overlay"></div>
              <div class="card-tag tag-cyan">战略合作</div>
            </div>
            <div class="card-content">
              <p class="card-date date-cyan">2026年03月28日</p>
              <h3 class="card-title">携手全球云服务巨头，共建"零碳"数字基座计划</h3>
              <p class="card-text">极致科技将发挥其在算法降耗方面的专长，通过自适应算力路由技术降低数据中心 15% 以上的电力消耗。</p>
              <div class="card-footer">
                <div class="view-count">
                  <span class="eye-icon">👁</span>
                  <span>856 阅读</span>
                </div>
                <span class="share-icon">⤴</span>
              </div>
            </div>
          </div>

          <!-- 动态卡片 3 -->
          <div class="dynamics-card card-purple">
            <div class="card-image-wrapper">
              <img src="https://images.unsplash.com/photo-1581091226825-a6a2a5aee158?auto=format&fit=crop&q=80&w=800" alt="Exhibition" class="card-image" />
              <div class="image-overlay"></div>
              <div class="card-tag tag-purple">行业荣誉</div>
            </div>
            <div class="card-content">
              <p class="card-date date-purple">2026年03月15日</p>
              <h3 class="card-title">荣获 2026 世界数字经济大会"最具影响力创新奖"</h3>
              <p class="card-text">凭借在隐私计算与分布式引擎方面的突破性表现，极致科技从全球 500 多家参评机构中脱颖而出。</p>
              <div class="card-footer">
                <div class="view-count">
                  <span class="eye-icon">👁</span>
                  <span>2.1k 阅读</span>
                </div>
                <span class="share-icon">⤴</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <Footer />
  </div>
</Layout>

<style>
  @import '../styles/dynamics.scss';
</style>

<script>
  // 卡片悬停效果增强
  const cards = document.querySelectorAll('.dynamics-card');
  cards.forEach((card, index) => {
    card.style.animationDelay = `${index * 100}ms`;
  });
</script>
