---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
---

<Layout title="测试服务 - 企业官网">
  <div class="page-container">
    <Navbar />

    <section class="test-service-section">
      <!-- 顶部椭圆装饰 -->
      <div class="top-ellipse"></div>

      <!-- 顶部标题区 -->
      <div class="test-header">
        <h2 class="header-title">全生命周期测试服务</h2>
        <p class="header-desc">
          凭借在软件测试领域多年的技术沉淀和丰富的行业实战经验，为全球客户提供专业、高效、全栈的质量保证服务。我们构建了完善的自动化测试体系与性能压测中心，助力企业交付零缺陷的高品质数字化产品。
        </p>
      </div>

      <!-- 精益测试流程区 -->
      <div class="process-section">
        <div class="process-bg-ellipse"></div>
        <h3 class="process-title">精益测试流程</h3>
        <div class="process-steps">
          <!-- 步骤1 -->
          <div class="process-step">
            <div class="step-number">01</div>
            <h4 class="step-title">策略规划</h4>
            <p class="step-desc">
              分析项目特性，制定测试计划、风险评估方案及环境搭建清单。
            </p>
          </div>
          <!-- 步骤2 -->
          <div class="process-step">
            <div class="step-number">02</div>
            <h4 class="step-title">设计执行</h4>
            <p class="step-desc">
              编写高质量测试用例，执行自动化脚本，全覆盖功能与渗透链路。
            </p>
          </div>
          <!-- 步骤3 -->
          <div class="process-step">
            <div class="step-number">03</div>
            <h4 class="step-title">缺陷治理</h4>
            <p class="step-desc">
              精准定位缺陷根因，协同开发闭环修复，执行严格的回归测试。
            </p>
          </div>
          <!-- 步骤4 -->
          <div class="process-step">
            <div class="step-number">04</div>
            <h4 class="step-title">交付报告</h4>
            <p class="step-desc">
              多维质量度量评估，产出权威测试报告，为产品上线提供决策支持。
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- 测试服务详情 + 精选案例模块 -->
    <section class="test-service-detail-section">
      <!-- 椭圆背景装饰 -->
      <div class="bg-ellipse ellipse-1"></div>
      <div class="bg-ellipse ellipse-2"></div>

      <!-- 顶部服务卡片区 -->
      <div class="service-cards">
        <!-- 自动化测试 -->
        <div class="service-card">
          <div class="card-header">
            <div class="card-icon">
              <svg viewBox="0 0 24 24" fill="#3a78f5" stroke="none">
                <path d="M12 2a5 5 0 0 0-5 5v1a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1V7a5 5 0 0 0-5-5zm0 14a3 3 0 1 0 0-6 3 3 0 0 0 0 6z"/>
                <path d="M5 13a3 3 0 0 0-3 3v2a1 1 0 0 0 1 1h14a1 1 0 0 0 1-1v-2a3 3 0 0 0-3-3H5z"/>
              </svg>
            </div>
            <span class="card-tag">Automation</span>
          </div>
          <h3 class="card-title">自动化测试</h3>
          <p class="card-desc">
            自主研发自动化测试框架，覆盖UI、接口、单元测试，实现测试脚本分钟级执行，显著提升回归效率。
          </p>
          <ul class="card-list">
            <li>Web/App UI 自动化</li>
            <li>RESTful API 自动化</li>
            <li>数据驱动测试 (DDT)</li>
          </ul>
        </div>

        <!-- 性能压测服务 -->
        <div class="service-card">
          <div class="card-header">
            <div class="card-icon">
              <svg viewBox="0 0 24 24" fill="#3a78f5" stroke="none">
                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8z"/>
                <path d="M12 6c-3.31 0-6 2.69-6 6s2.69 6 6 6 6-2.69 6-6-2.69-6-6-6zm0 10c-2.21 0-4-1.79-4-4s1.79-4 4-4 4 1.79 4 4-1.79 4-4 4z"/>
              </svg>
            </div>
            <span class="card-tag">Performance</span>
          </div>
          <h3 class="card-title">性能压测服务</h3>
          <p class="card-desc">
            全链路压测解决方案，模拟高并发极端场景，精准分析系统瓶颈，提供全方位的调优建议。
          </p>
          <ul class="card-list">
            <li>负载/压力测试</li>
            <li>系统瓶颈分析</li>
            <li>资源利用率监控</li>
          </ul>
        </div>

        <!-- 安全渗透测试 -->
        <div class="service-card">
          <div class="card-header">
            <div class="card-icon">
              <svg viewBox="0 0 24 24" fill="#3a78f5" stroke="none">
                <path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4z"/>
              </svg>
            </div>
            <span class="card-tag">Security</span>
          </div>
          <h3 class="card-title">安全渗透测试</h3>
          <p class="card-desc">
            由资深安全专家团队执行黑盒/白盒渗透，深度挖掘业务渗透漏洞，全方位保障应用系统安全。
          </p>
          <ul class="card-list">
            <li>Web/App 漏洞扫描</li>
            <li>代码审计</li>
            <li>风险合规评估</li>
          </ul>
        </div>
      </div>

      <!-- 精选案例区 -->
      <div class="case-section">
        <h2 class="section-title">精选案例</h2>
        <div class="case-cards">
          <!-- 某互联网券商全链路压测 -->
          <div class="case-card">
            <div class="card-icon">
              <svg viewBox="0 0 24 24" fill="#3a78f5" stroke="none">
                <path d="M3 13h8V3H3v10zm0 8h8v-6H3v6zm10 0h8V11h-8v10zm0-18v6h8V3h-8z"/>
                <path d="M13 13h8v-2h-8v2z"/>
              </svg>
            </div>
            <div class="card-content">
              <h3 class="card-title">某互联网券商全链路压测</h3>
              <p class="card-desc">
                在股市交易高峰期前，为其核心交易系统实施了百万级并发的全链路压测，成功发现并协助优化了3处严重的数据瓶颈，确保了开市期间零宕机。
              </p>
            </div>
          </div>

          <!-- 知名短视频平台自动化体系建设 -->
          <div class="case-card">
            <div class="card-icon">
              <svg viewBox="0 0 24 24" fill="#3a78f5" stroke="none">
                <path d="M17 1.01L7 1c-1.1 0-2 .9-2 2v18c0 1.1.9 2 2 2h10c1.1 0 2-.9 2-2V3c0-1.1-.9-1.99-2-1.99zM17 19H7V5h10v14z"/>
                <path d="M15 11H9v2h6v-2z"/>
              </svg>
            </div>
            <div class="card-content">
              <h3 class="card-title">知名短视频平台自动化体系建设</h3>
              <p class="card-desc">
                为其建立了覆盖Android/iOS/Web三端的UI自动化测试中心，实现日均100+个版本的全量回归，人力成本降低70%，发布周期缩短至小时级。
              </p>
            </div>
          </div>

          <!-- 智慧医院集成化系统质量评估 -->
          <div class="case-card">
            <div class="card-icon">
              <svg viewBox="0 0 24 24" fill="#3a78f5" stroke="none">
                <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-5 14H7v-2h7v2zm3-4H7v-2h10v2zm0-4H7V7h10v2z"/>
                <path d="M9 11h2v2H9v-2zm4 0h2v2h-2v-2z"/>
              </svg>
            </div>
            <div class="card-content">
              <h3 class="card-title">智慧医院集成化系统质量评估</h3>
              <p class="card-desc">
                对某三甲医院的HIS/LIS/PACS系统进行深度的集成兼容性测试与安全性评估，涉及上百个子系统对接，确保了医疗数据的准确传输与高可用性。
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <Footer />
  </div>
</Layout>

<style>
/* 全局背景 */
.page-container {
  background: #0a1028;
}

/* 主容器 */
.test-service-section {
  width: 100%;
  min-height: 800px;
  background: #0a1028;
  position: relative;
  overflow: visible;
  padding: 60px 12%;
}

/* 顶部椭圆装饰 */
.top-ellipse {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 300px;
  background: rgba(58, 78, 213, 0.15);
  border-radius: 50% 50% 0 0;
  z-index: 1;
  pointer-events: none;
}

/* ========== 顶部标题区 ========== */
.test-header {
  position: relative;
  z-index: 2;
  text-align: center;
  margin-bottom: 80px;
}

.header-title {
  font-size: 42px;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 20px;
}

.header-desc {
  font-size: 18px;
  color: #c2c7d6;
  line-height: 1.8;
  max-width: 900px;
  margin: 0 auto;
}

/* ========== 精益测试流程区 ========== */
.process-section {
  position: relative;
  z-index: 2;
  background: rgba(58, 78, 213, 0.08);
  border-radius: 0 0 50% 50%;
  padding: 60px 0;
}

.process-bg-ellipse {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(58, 78, 213, 0.05);
  border-radius: 0 0 50% 50%;
  z-index: 1;
  pointer-events: none;
}

.process-title {
  position: relative;
  z-index: 2;
  font-size: 28px;
  font-weight: 600;
  color: #ffffff;
  text-align: center;
  margin-bottom: 40px;
}

.process-steps {
  position: relative;
  z-index: 2;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 40px;
  max-width: 1400px;
  margin: 0 auto;
  padding: 0 20px;
}

.process-step {
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16px;
}

.step-number {
  width: 50px;
  height: 50px;
  background: #3a78f5;
  border-radius: 50%;
  color: #ffffff;
  font-size: 20px;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8px;
}

.step-title {
  font-size: 20px;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 8px;
}

.step-desc {
  font-size: 14px;
  color: #c2c7d6;
  line-height: 1.7;
  max-width: 280px;
}

/* ========== 响应式适配 ========== */
@media (max-width: 1024px) {
  .process-steps {
    grid-template-columns: repeat(2, 1fr);
    gap: 30px;
  }
  .header-title {
    font-size: 32px;
  }
}

@media (max-width: 768px) {
  .test-service-section {
    padding: 40px 5%;
  }
  .process-steps {
    grid-template-columns: 1fr;
  }
  .header-title {
    font-size: 28px;
  }
  .header-desc {
    font-size: 16px;
  }
}

/* ========== 测试服务详情 + 精选案例模块 ========== */
.test-service-detail-section {
  width: 100%;
  min-height: 900px;
  background: #0a1028;
  position: relative;
  overflow: visible;
  padding: 60px 12%;
}

/* 椭圆背景装饰 */
.bg-ellipse {
  position: absolute;
  border-radius: 50%;
  background: rgba(58, 78, 213, 0.1);
  z-index: 1;
  pointer-events: none;
}

.ellipse-1 {
  width: 120%;
  height: 50%;
  top: 0;
  left: -10%;
  background: rgba(58, 78, 213, 0.12);
}

.ellipse-2 {
  width: 120%;
  height: 70%;
  bottom: 0;
  left: -10%;
  background: rgba(58, 78, 213, 0.08);
}

/* ========== 顶部服务卡片区 ========== */
.service-cards {
  position: relative;
  z-index: 2;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 30px;
  margin-bottom: 80px;
}

.service-card {
  background: rgba(255, 255, 255, 0.04);
  border: 1px solid rgba(58, 120, 245, 0.2);
  border-radius: 16px;
  padding: 32px 28px;
  backdrop-filter: blur(8px);
  transition: all 0.3s ease;
}

.service-card:hover {
  background: rgba(58, 120, 245, 0.08);
  border-color: rgba(58, 120, 245, 0.5);
  transform: translateY(-6px);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20px;
}

.service-card .card-icon {
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.service-card .card-icon svg {
  width: 28px;
  height: 28px;
}

.card-tag {
  font-size: 12px;
  color: #c2c7d6;
  background: rgba(255, 255, 255, 0.05);
  padding: 4px 12px;
  border-radius: 4px;
  text-transform: capitalize;
}

.service-card .card-title {
  font-size: 20px;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 16px;
}

.service-card .card-desc {
  font-size: 14px;
  color: #c2c7d6;
  line-height: 1.7;
  margin-bottom: 20px;
}

.card-list {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.card-list li {
  font-size: 13px;
  color: #aab2c7;
  padding-left: 16px;
  position: relative;
}

.card-list li::before {
  content: "•";
  position: absolute;
  left: 0;
  color: #3a78f5;
  font-weight: bold;
}

/* ========== 精选案例区 ========== */
.case-section {
  position: relative;
  z-index: 2;
}

.section-title {
  font-size: 28px;
  font-weight: 600;
  color: #ffffff;
  text-align: center;
  margin-bottom: 40px;
}

.case-cards {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 30px;
}

.case-card {
  background: rgba(255, 255, 255, 0.04);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 12px;
  padding: 24px;
  display: flex;
  gap: 20px;
  backdrop-filter: blur(8px);
  transition: all 0.3s ease;
}

.case-card:hover {
  background: rgba(58, 120, 245, 0.08);
  border-color: rgba(58, 120, 245, 0.4);
}

.case-card .card-icon {
  width: 60px;
  height: 60px;
  background: rgba(58, 120, 245, 0.1);
  border-radius: 8px;
  flex-shrink: 0;
}

.case-card .card-icon svg {
  width: 32px;
  height: 32px;
}

.case-card .card-content {
  flex: 1;
}

.case-card .card-title {
  font-size: 18px;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 12px;
}

.case-card .card-desc {
  font-size: 14px;
  color: #c2c7d6;
  line-height: 1.7;
}

/* 第三张案例卡片占满整行 */
.case-cards .case-card:nth-child(3) {
  grid-column: 1 / -1;
}

/* 详情模块响应式适配 */
@media (max-width: 1024px) {
  .service-cards {
    grid-template-columns: repeat(2, 1fr);
  }
  .case-cards {
    grid-template-columns: 1fr;
  }
  .case-cards .case-card:nth-child(3) {
    grid-column: auto;
  }
}

@media (max-width: 768px) {
  .test-service-detail-section {
    padding: 40px 5%;
  }
  .service-cards, .case-cards {
    grid-template-columns: 1fr;
  }
  .section-title {
    font-size: 24px;
  }
}
</style>
