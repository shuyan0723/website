---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
---

<Layout title="云服务 - 企业官网">
  <div class="page-container">
    <Navbar />

    <section class="cloud-service-section">
      <!-- 顶部椭圆装饰 -->
      <div class="top-ellipse"></div>

      <!-- 顶部标题区 -->
      <div class="cloud-header">
        <div class="header-content">
          <h2 class="header-title">专业的一站式云服务</h2>
          <p class="header-desc">
            不断发掘技术增长与创新价值点，通过新技术和行业特征的有效结合，为客户提供专业的上云、用云、管云，一站式服务的能力，赋能客户云化，助力上云"最后一公里"。
          </p>
          <div class="header-tags">
            <button class="tag-btn">
              <svg viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2">
                <path d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z"/>
              </svg>
              专业上云
            </button>
            <button class="tag-btn">
              <svg viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2">
                <path d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 0 0 2.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 0 0 1.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 0 0-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 0 0-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 0 0-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 0 0-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 0 0 1.066-2.573c-.94-1.543.826-3.31 2.37-2.37 1 .604 2.216.029 2.572-1.065z"/>
                <circle cx="12" cy="12" r="3"/>
              </svg>
              精细管云
            </button>
            <button class="tag-btn">
              <svg viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2">
                <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
              </svg>
              高效用云
            </button>
          </div>
        </div>

        <!-- 右侧云装饰 -->
        <div class="cloud-decoration">
          <div class="dashed-ring"></div>
          <div class="cloud-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="#4a8eff" stroke-width="2">
              <path d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z"/>
            </svg>
          </div>
          <div class="decor-icon shield-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="#4a8eff" stroke-width="2">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
          </div>
          <div class="decor-icon trend-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="#4a8eff" stroke-width="2">
              <path d="M3 12l6-6 6 6 6-6"/>
            </svg>
          </div>
        </div>
      </div>

      <!-- 云服务生命周期区 -->
      <div class="lifecycle-section">
        <h3 class="lifecycle-title">云服务生命周期</h3>
        <div class="lifecycle-cards">
          <div class="lifecycle-card">
            <div class="card-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2">
                <circle cx="12" cy="12" r="10"/>
                <path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 8 15.3 15.3 0 0 1-4 8 15.3 15.3 0 0 1-4-8 15.3 15.3 0 0 1 4-8z"/>
              </svg>
            </div>
            <h4 class="card-title">上云规划与咨询</h4>
            <p class="card-desc">
              提供业务调研、上云可行性分析、云架构设计、迁移方案制定，确保上云过程平稳高效。
            </p>
            <span class="card-stage">规划阶段</span>
          </div>

          <div class="lifecycle-card">
            <div class="card-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2">
                <path d="M21.5 2v6h-6M2.5 22v-6h6M2 11.5a10 10 0 0 1 18.8-4.3M22 12.5a10 10 0 0 1-18.8 4.2"/>
              </svg>
            </div>
            <h4 class="card-title">云迁移与交付</h4>
            <p class="card-desc">
              专业的迁移工具和标准流程，支持数据库、文件、应用系统的无缝迁移及部署实施。
            </p>
            <span class="card-stage">实施阶段</span>
          </div>

          <div class="lifecycle-card">
            <div class="card-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2">
                <rect x="2" y="3" width="20" height="14" rx="2"/>
                <line x1="8" y1="21" x2="8" y2="17"/>
                <line x1="16" y1="21" x2="16" y2="17"/>
                <line x1="12" y1="17" x2="12" y2="13"/>
              </svg>
            </div>
            <h4 class="card-title">云管理与运维</h4>
            <p class="card-desc">
              7x24小时全栈云监控、安全审计、成本优化。让客户专注于核心业务增长。
            </p>
            <span class="card-stage">运营阶段</span>
          </div>
        </div>
      </div>
    </section>

    <!-- 云转型成功案例 + 云·合作伙伴模块 -->
    <section class="cloud-case-section">
      <!-- 椭圆背景装饰 -->
      <div class="bg-ellipse ellipse-1"></div>
      <div class="bg-ellipse ellipse-2"></div>

      <!-- 云转型成功案例区 -->
      <div class="case-section">
        <h2 class="section-title">云转型成功案例</h2>
        <div class="case-cards">
          <div class="case-card">
            <div class="card-bg"></div>
            <div class="card-content">
              <h3 class="card-title">某金融机构混合云架构转型</h3>
              <a href="#" class="card-link">查看详情 →</a>
            </div>
          </div>

          <div class="case-card">
            <div class="card-bg"></div>
            <div class="card-content">
              <h3 class="card-title">快消行业SAP系统全量上云</h3>
              <a href="#" class="card-link">查看详情 →</a>
            </div>
          </div>

          <div class="case-card">
            <div class="card-bg"></div>
            <div class="card-content">
              <h3 class="card-title">智慧城市云安全防护体系</h3>
              <a href="#" class="card-link">查看详情 →</a>
            </div>
          </div>
        </div>
      </div>

      <!-- 云·合作伙伴区 -->
      <div class="partner-section">
        <h2 class="section-title">云 · 合作伙伴</h2>
        <div class="partner-buttons">
          <button class="partner-btn">阿里云</button>
          <button class="partner-btn">华为云</button>
          <button class="partner-btn">腾讯云</button>
          <button class="partner-btn">AWS</button>
          <button class="partner-btn">Azure</button>
          <button class="partner-btn">百度智能云</button>
        </div>
      </div>
    </section>

    <Footer />
  </div>
</Layout>

<style>
/* 全局重置 */
.page-container {
  background: #0a1028;
}

/* 主容器：深色背景 + 椭圆装饰 */
.cloud-service-section {
  width: 100%;
  min-height: 800px;
  background: #0a1028;
  position: relative;
  overflow: visible;
  padding: 60px 12%;
}

/* 顶部椭圆装饰 */
.top-ellipse {
  position: absolute;
  top: 0px;
  left: 0;
  width: 100%;
  height: 400px;
  background: rgba(58, 78, 213, 0.15);
  border-radius: 50% 50% 0 0;
  z-index: 1;
  pointer-events: none;
}

/* ========== 顶部标题区 ========== */
.cloud-header {
  position: relative;
  z-index: 2;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 80px;
}

.header-content {
  max-width: 700px;
}

.header-title {
  font-size: 42px;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 20px;
}

.header-desc {
  font-size: 18px;
  color: #c2c7d6;
  line-height: 1.8;
  margin-bottom: 32px;
}

.header-tags {
  display: flex;
  gap: 16px;
}

.tag-btn {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 8px 20px;
  background: rgba(58, 120, 245, 0.15);
  border: 1px solid rgba(58, 120, 245, 0.3);
  border-radius: 8px;
  color: #ffffff;
  font-size: 15px;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.3s ease;
}

.tag-btn:hover {
  background: rgba(58, 120, 245, 0.3);
  border-color: rgba(58, 120, 245, 0.6);
}

.tag-btn svg {
  width: 18px;
  height: 18px;
}

/* 右侧云装饰 */
.cloud-decoration {
  position: relative;
  width: 220px;
  height: 220px;
}

.dashed-ring {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  border: 2px dashed rgba(58, 120, 245, 0.4);
  border-radius: 50%;
  z-index: 1;
}

.cloud-icon {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 160px;
  height: 160px;
  background: rgba(58, 120, 245, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
}

.cloud-icon svg {
  width: 60px;
  height: 60px;
  stroke-width: 3;
}

.decor-icon {
  position: absolute;
  width: 24px;
  height: 24px;
  z-index: 3;
}

.shield-icon {
  top: -10px;
  right: 10px;
}

.trend-icon {
  bottom: 20px;
  left: 10px;
}

/* ========== 生命周期区 ========== */
.lifecycle-section {
  position: relative;
  z-index: 2;
  background: rgba(58, 78, 213, 0.08);
  border-radius: 0 0 50% 50%;
  padding: 100px 0 60px;
}

.lifecycle-title {
  font-size: 28px;
  font-weight: 600;
  color: #ffffff;
  text-align: center;
  margin-bottom: 40px;
}

.lifecycle-cards {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 30px;
  max-width: 1200px;
  margin: 0 auto;
}

.lifecycle-card {
  background: rgba(255, 255, 255, 0.04);
  border: 1px solid rgba(58, 120, 245, 0.2);
  border-radius: 16px;
  padding: 32px 24px;
  text-align: center;
  backdrop-filter: blur(8px);
  transition: all 0.3s ease;
}

.lifecycle-card:hover {
  background: rgba(58, 120, 245, 0.08);
  border-color: rgba(58, 120, 245, 0.5);
  transform: translateY(-6px);
}

.card-icon {
  width: 48px;
  height: 48px;
  background: #3a78f5;
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: -56px auto 16px;
}

.card-icon svg {
  width: 24px;
  height: 24px;
}

.card-title {
  font-size: 20px;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 12px;
}

.card-desc {
  font-size: 14px;
  color: #c2c7d6;
  line-height: 1.7;
  margin-bottom: 16px;
}

.card-stage {
  font-size: 13px;
  color: #3a78f5;
  font-weight: 500;
}

/* ========== 响应式适配 ========== */
@media (max-width: 1024px) {
  .cloud-header {
    flex-direction: column;
    text-align: center;
    gap: 40px;
  }
  .lifecycle-cards {
    grid-template-columns: repeat(2, 1fr);
  }
  .header-title {
    font-size: 32px;
  }
}

@media (max-width: 768px) {
  .cloud-service-section {
    padding: 40px 5%;
  }
  .lifecycle-cards {
    grid-template-columns: 1fr;
  }
  .header-title {
    font-size: 28px;
  }
  .header-desc {
    font-size: 16px;
  }
  .header-tags {
    flex-direction: column;
    align-items: center;
  }
}

/* ========== 云转型成功案例 + 云·合作伙伴模块 ========== */
.cloud-case-section {
  width: 100%;
  background: #0a1028;
  position: relative;
  overflow: visible;
  padding: 60px 12% 80px;
}

/* 椭圆背景装饰 */
.bg-ellipse {
  position: absolute;
  border-radius: 50%;
  background: rgba(58, 78, 213, 0.1);
  z-index: 1;
  pointer-events: none;
}

.ellipse-1 {
  width: 120%;
  height: 60%;
  top: 0;
  left: -10%;
  background: rgba(58, 78, 213, 0.12);
}

.ellipse-2 {
  width: 120%;
  height: 60%;
  bottom: 0;
  left: -10%;
  background: rgba(58, 78, 213, 0.08);
}

.section-title {
  position: relative;
  z-index: 2;
  font-size: 28px;
  font-weight: 600;
  color: #ffffff;
  text-align: center;
  margin-bottom: 40px;
}

/* 云转型成功案例区 */
.case-section {
  position: relative;
  z-index: 2;
  margin-bottom: 80px;
}

.case-cards {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 30px;
  max-width: 1200px;
  margin: 0 auto;
}

.case-card {
  position: relative;
  height: 280px;
  border-radius: 8px;
  overflow: hidden;
  cursor: pointer;
  transition: transform 0.3s ease;
}

.case-card:hover {
  transform: translateY(-6px);
}

.card-bg {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, rgba(10, 16, 40, 0.9) 0%, rgba(58, 78, 213, 0.3) 100%);
  position: relative;
}

.card-bg::before {
  content: "";
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 60px;
  height: 60px;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 8px;
}

.card-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24px;
  background: linear-gradient(to top, rgba(10, 16, 40, 0.9) 0%, transparent 100%);
}

.card-title {
  font-size: 18px;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 16px;
  line-height: 1.4;
}

.card-link {
  font-size: 13px;
  color: #3a78f5;
  text-decoration: none;
  font-weight: 500;
  transition: color 0.3s ease;
}

.card-link:hover {
  color: #4a8eff;
}

/* 云·合作伙伴区 */
.partner-section {
  position: relative;
  z-index: 2;
}

.partner-buttons {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 20px;
  max-width: 1200px;
  margin: 0 auto;
}

.partner-btn {
  padding: 16px 24px;
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 8px;
  color: #c2c7d6;
  font-size: 16px;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.3s ease;
}

.partner-btn:hover {
  background: rgba(58, 120, 245, 0.15);
  border-color: rgba(58, 120, 245, 0.4);
  color: #ffffff;
}

/* 新模块响应式适配 */
@media (max-width: 1024px) {
  .case-cards {
    grid-template-columns: repeat(2, 1fr);
  }
  .partner-buttons {
    grid-template-columns: repeat(3, 1fr);
  }
}

@media (max-width: 768px) {
  .cloud-case-section {
    padding: 40px 5% 60px;
  }
  .case-cards, .partner-buttons {
    grid-template-columns: 1fr;
  }
  .section-title {
    font-size: 24px;
  }
}
</style>
