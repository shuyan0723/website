---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="客户案例 - 企业官网">
  <div class="page-container">
    <Navbar />
    <div class="page-content">
      <h1>客户案例</h1>
      <p class="subtitle">携手共创，成就卓越</p>
    </div>
    <Footer />
  </div>
</Layout>

<style>
  .page-content {
    min-height: calc(100vh - 80px);
    padding: 120px 12% 60px;
    text-align: center;
  }

  .page-content h1 {
    font-size: 48px;
    font-weight: 700;
    color: #111827;
    margin-bottom: 16px;
  }

  .subtitle {
    font-size: 18px;
    color: #666;
  }
</style>
