---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="关于我们 - 企业官网">
  <div class="page-container">
    <Navbar />

    <section class="about-footer-section">
      <div class="about-container">
        <!-- 顶部标题区 -->
        <div class="about-header">
          <h2 class="header-title">连接技术与商业的<br>数字进化伙伴</h2>
          <p class="header-desc">
            昆仑时代（上海）系统集成有限公司成立于 2018 年，是一家领先的全球化软件与信息技术服务商。我们致力于通过前沿的云计算、人工智能和大数据技术，为全球企业提供卓越的数字化转型服务。
          </p>
        </div>

        <!-- 内容区 -->
        <div class="about-content">
          <!-- 左侧使命愿景 -->
          <div class="about-left">
            <div class="about-item">
              <h3 class="item-title">我们的使命</h3>
              <p class="item-desc">
                驱动数字化，成就卓越未来。我们相信技术的力量可以改变世界，通过持续的创新和专业的服务，帮助客户在快速变化的数字时代保持领先地位。
              </p>
            </div>
            <div class="about-item">
              <h3 class="item-title">我们的愿景</h3>
              <p class="item-desc">
                成为全球最值得信赖的数字化转型合作伙伴。无论是在核心系统开发还是前沿技术探索，昆仑时代始终坚持以客户为中心，追求极致的交付品质。
              </p>
            </div>
          </div>

          <!-- 右侧加入我们卡片 -->
          <div class="about-right">
            <div class="join-card">
              <h3 class="join-title">加入我们</h3>
              <p class="join-desc">
                我们正在寻找充满激情、勇于挑战的伙伴。在昆仑时代，你将有机会参与最前沿的技术项目，与全球顶尖的工程师并肩作战。
              </p>
              <button class="join-btn">查看开放职位</button>
            </div>
          </div>
        </div>
      </div>
    </section>

    <Footer />
  </div>
</Layout>

<style>
/* 全局背景 */
.page-container {
  background: #0a1028;
}

/* 主容器：深色背景 */
.about-footer-section {
  width: 100%;
  min-height: 700px;
  background: #0a1028;
  position: relative;
  overflow: hidden;
  padding: 60px 12%;
}

/* 顶部装饰线 */
.about-footer-section::before {
  content: "";
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60px;
  height: 3px;
  background: #3a78f5;
  border-radius: 2px;
}

/* 容器 */
.about-container {
  position: relative;
  z-index: 2;
  max-width: 1400px;
  margin: 0 auto;
}

/* ========== 顶部标题区 ========== */
.about-header {
  text-align: center;
  margin-bottom: 100px;
}

.header-title {
  font-size: 42px;
  font-weight: 700;
  color: #ffffff;
  line-height: 1.3;
  margin-bottom: 24px;
}

.header-desc {
  font-size: 17px;
  color: #c2c7d6;
  line-height: 1.8;
  max-width: 800px;
  margin: 0 auto;
}

/* ========== 内容区 ========== */
.about-content {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 60px;
}

/* 左侧使命愿景 */
.about-left {
  flex: 1;
  max-width: 580px;
  display: flex;
  flex-direction: column;
  gap: 32px;
}

.about-item {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.item-title {
  font-size: 26px;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 8px;
}

.item-desc {
  font-size: 15px;
  color: #c2c7d6;
  line-height: 1.7;
}

/* 右侧加入我们卡片 */
.about-right {
  flex: 1;
  max-width: 520px;
  margin-top: 3px;
}

.join-card {
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 20px;
  padding: 36px;
  backdrop-filter: blur(10px);
  box-shadow: 0 8px 32px rgba(58, 120, 245, 0.1);
}

.join-title {
  font-size: 28px;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 20px;
}

.join-desc {
  font-size: 15px;
  color: #c2c7d6;
  line-height: 1.7;
  margin-bottom: 28px;
}

.join-btn {
  width: 100%;
  padding: 16px 32px;
  background: #2563eb;
  color: #ffffff;
  border: none;
  border-radius: 12px;
  font-size: 16px;
  font-weight: 600;
  cursor: pointer;
  transition: background 0.3s ease;
}

.join-btn:hover {
  background: #1d4ed8;
}

/* ========== 响应式适配 ========== */
@media (max-width: 1024px) {
  .about-content {
    flex-direction: column;
    gap: 40px;
  }
  .header-title {
    font-size: 32px;
  }
}

@media (max-width: 768px) {
  .about-footer-section {
    padding: 40px 5%;
  }
  .header-title {
    font-size: 28px;
  }
  .header-desc {
    font-size: 15px;
  }
  .item-title {
    font-size: 22px;
  }
  .join-title {
    font-size: 24px;
  }
}
</style>
