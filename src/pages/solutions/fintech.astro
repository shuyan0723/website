    <!-- 服务优势 -->
    <section class="advantages-section" id="advantages">
      <div class="max-container">
        <div class="section-header fade-in">
          <span class="section-badge">🏆 核心优势</span>
          <h2 class="section-title">我们的优势</h2>
          <p class="section-desc">专业团队与成熟技术体系，为您的金融业务保驾护航</p>
        </div>

        <div class="advantages-grid">
          <div class="advantage-card fade-in" data-delay="100">
            <div class="advantage-number blue">01</div>
            <h4 class="advantage-title">经验丰富</h4>
            <p class="advantage-desc">专注金融业多年服务方案供应商，行业领域经验丰富</p>
          </div>

          <div class="advantage-card fade-in" data-delay="200">
            <div class="advantage-number purple">02</div>
            <h4 class="advantage-title">合作共赢</h4>
            <p class="advantage-desc">国内外大中小金融机构战略合作</p>
          </div>

