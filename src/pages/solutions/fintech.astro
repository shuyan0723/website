            <div class="case-content">
              <span class="case-tag purple">证券科技</span>
              <h4 class="case-title">知名券商智能化交易平台</h4>
              <p class="case-desc">毫秒级交易响应，助力数字化财富管理转型。</p>
              <div class="case-badges">
                <span class="mini-tag purple">低延迟</span>
                <span class="mini-tag purple">智能交易</span>
              </div>
            </div>
          </div>
        </div>

        <!-- 小案例卡片 -->
        <div class="mini-cases">
          <div class="mini-card fade-in" data-delay="300">
            <div class="mini-card-icon green">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <div class="mini-card-content">
              <span class="mini-card-label">保险科技</span>
