---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
---

<Layout title="金融科技 - 昆仑时代 - 全球化软件与信息技术服务商">
  <div class="page-container">
    <Navbar />

    <!-- 英雄区 -->
    <section class="hero-section" id="hero">
      <div class="max-container">
        <div class="hero-badge">
          <span class="badge-text">🚀 数字化转型先锋</span>
        </div>
        <h1 class="hero-title">金融科技</h1>
        <p class="hero-desc">
          基于金融业的银行、证券、基金、保险等业务系统，提供端到端的软件服务。我们拥有一支经验丰富的金融业服务团队和技术支撑团队，在金融云服务、互联网金融、以及基于大数据的数据分析和营销服务等业务领域拥有众多专业解决方案。
        </p>
        <div class="hero-actions">
          <a href="#services" class="btn-primary">探索服务 →</a>
          <a href="#contact" class="btn-secondary">预约咨询</a>
        </div>
      </div>
    </section>

    <!-- 服务模块 -->
    <section class="services-section" id="services">
      <div class="max-container">
        <div class="section-header fade-in">
          <span class="section-badge">💼 核心服务</span>
          <h2 class="section-title">核心服务</h2>
          <p class="section-desc">我们提供全面的金融科技解决方案，助力企业数字化转型</p>
        </div>

        <div class="services-grid">
          <div class="service-card card-hover fade-in" data-delay="100">
            <div class="service-icon blue">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
              </svg>
            </div>
            <h3 class="service-title">核心业务系统</h3>
            <p class="service-desc">提供银行核心存款、贷款、支付结算等基础业务系统的开发与运维。</p>
            <div class="service-tags">
              <span class="tag blue">银行系统</span>
              <span class="tag blue">支付结算</span>
            </div>
          </div>

          <div class="service-card card-hover fade-in" data-delay="200">
            <div class="service-icon purple">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M7 12l3-3 3 3 4-4M8 21l4-4 4 4M3 4h18M4 4h16v12a1 1 0 01-1 1H5a1 1 0 01-1-1V4z"/>
              </svg>
            </div>
            <h3 class="service-title">数字财富管理</h3>
            <p class="service-desc">助力证券与基金行业构建智能投顾、资产管理及大数据营销平台。</p>
            <div class="service-tags">
              <span class="tag purple">智能投顾</span>
