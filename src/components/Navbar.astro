---
const currentPath = Astro.url.pathname;
---

<nav class="navbar">
  <ul class="nav-list">
    <li><a href="/" class={currentPath === '/' ? 'active' : ''}>首页</a></li>
    <li><a href="/products" class={currentPath.startsWith('/products') ? 'active' : ''}>产品服务</a></li>
    <li><a href="/research" class={currentPath.startsWith('/research') ? 'active' : ''}>研发中心</a></li>
    <li><a href="/dynamics" class={currentPath.startsWith('/dynamics') ? 'active' : ''}>企业动态</a></li>
    <li><a href="/news" class={currentPath.startsWith('/news') ? 'active' : ''}>新闻中心</a></li>
    <li><a href="/cases" class={currentPath.startsWith('/cases') ? 'active' : ''}>客户案例</a></li>
    <li><a href="/about" class={currentPath.startsWith('/about') ? 'active' : ''}>关于我们</a></li>
  </ul>
  <a href="/contact" class="contact-btn">联系我们</a>
</nav>

<style>
  .navbar {
    height: 80px;
    background: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    border-bottom: 1px solid #f0f0f0;
    position: relative;
    z-index: 10;
  }

  .nav-list {
    display: flex;
    gap: 38px;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .nav-list li a {
    text-decoration: none;
    color: #111;
    font-size: 15px;
    font-weight: 500;
    transition: color 0.2s ease;
  }

  .nav-list li a:hover,
  .nav-list li a.active {
    color: #3a4ed5;
    font-weight: 600;
  }

  .contact-btn {
    position: absolute;
    right: 20%;
    padding: 10px 28px;
    background: #3a78f5;
    color: #fff;
    border: none;
    border-radius: 24px;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    text-decoration: none;
    transition: background 0.2s ease;
  }

  .contact-btn:hover {
    background: #2a5ee5;
  }

  /* 响应式 */
  @media (max-width: 1024px) {
    .contact-btn {
      right: 5%;
    }
  }

  @media (max-width: 768px) {
    .navbar {
      flex-direction: column;
      height: auto;
      padding: 15px 0;
    }

    .nav-list {
      flex-wrap: wrap;
      justify-content: center;
      gap: 20px;
    }

    .contact-btn {
      position: static;
      margin-top: 15px;
    }
  }
</style>
