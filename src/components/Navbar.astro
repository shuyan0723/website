---
const currentPath = Astro.url.pathname;
---

<nav class="navbar">
  <ul class="nav-list">
    <li><a href="/" class={currentPath === '/' ? 'active' : ''}>首页</a></li>
    <li><a href="/solutions" class={currentPath === '/solutions' ? 'active' : ''}>行业方案</a></li>
    <li><a href="/services" class={currentPath === '/services' ? 'active' : ''}>服务范围</a></li>
    <li><a href="/about" class={currentPath === '/about' ? 'active' : ''}>关于我们</a></li>
    <li><a href="/cases" class={currentPath === '/cases' ? 'active' : ''}>成功案例</a></li>
  </ul>
  <a href="/contact" class="contact-btn">联系我们</a>
</nav>

<style>
  .navbar {
    height: 80px;
    background: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    border-bottom: 1px solid #f0f0f0;
    position: relative;
    z-index: 10;
  }

  .nav-list {
    display: flex;
    gap: 40px;
    list-style: none;
  }

  .nav-list li a {
    text-decoration: none;
    color: #333;
    font-size: 16px;
    font-weight: 500;
  }

  .nav-list li a:hover,
  .nav-list li a.active {
    color: #3a4ed5;
  }

  .contact-btn {
    position: absolute;
    right: 20%;
    padding: 10px 28px;
    background: #3a78f5;
    color: #fff;
    border: none;
    border-radius: 24px;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    text-decoration: none;
  }

  .contact-btn:hover {
    background: #2a5ee5;
  }
</style>
