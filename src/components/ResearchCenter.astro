---
// 研发中心组件
---

<!-- 研发中心主模块 -->
<section class="research-center-section bg-tech-dots" id="research-center">
  <!-- 背景装饰 -->
  <div class="research-center-bg-decoration"></div>
  <div class="research-center-bg-decoration right"></div>

  <div class="research-center-container">
    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <!-- 一、研发中心简介（Hero入口） -->
    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <div class="research-hero fade-in">
      <!-- 左侧内容 -->
      <div class="research-hero-content">
        <div class="research-hero-title-wrapper">
          <div class="research-hero-indicator"></div>
          <h2 class="research-hero-title">昆仑时代研发中心</h2>
        </div>
        <p class="research-hero-subtitle">KUNLUN R&D CENTER</p>
        <div class="research-hero-description">
          <p>昆仑时代成立于2020年，致力于成为中国领先、国际化的IT服务与数字化运营专家。</p>
          <p>聚焦金融、智能制造及政企领域，提供覆盖软件研发、系统集成、数字化运营及AI赋能的一体化解决方案。</p>
          <p>通过标准化、流程化、专业化的交付体系，构建"产品+解决方案+服务"的协同能力。</p>
        </div>
        <div class="research-hero-badges">
          <span class="research-hero-badge">国家高新技术企业</span>
          <span class="research-hero-badge">CNAS实验室认证</span>
        </div>
      </div>

      <!-- 右侧数据卡片 -->
      <div class="research-hero-stats">
        <div class="research-stats-card glass-morphism">
          <div class="research-stats-grid">
            <div class="research-stat-item">
              <div class="research-stat-number count-up" data-target="110">0</div>
              <p class="research-stat-label">软件著作权</p>
            </div>
            <div class="research-stat-item">
              <div class="research-stat-number count-up" data-target="120">0</div>
              <p class="research-stat-label">核心专利</p>
            </div>
            <div class="research-stat-item">
              <div class="research-stat-number count-up" data-target="200">0</div>
              <p class="research-stat-label">研发团队</p>
            </div>
            <div class="research-stat-item">
              <div class="research-stat-number count-up" data-target="50">0</div>
              <p class="research-stat-label">年均项目</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <!-- 二、核心技术（四大支柱网格） -->
    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <div class="research-core-tech">
      <div class="research-section-header fade-in">
        <div class="research-section-title-wrapper">
          <div class="research-section-indicator"></div>
          <h3 class="research-section-title">核心技术</h3>
          <span class="research-section-subtitle">Core Technology</span>
        </div>
        <p class="research-section-desc">以原创技术驱动产业变革</p>
      </div>

      <div class="research-tech-grid">
        <!-- 数据智能架构 -->
        <div class="research-tech-card fade-in stagger-1">
          <div class="research-tech-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2L2 7l10 5 10-5-10-5z"/>
              <path d="M2 17l10 5 10-5"/>
              <path d="M2 12l10 5 10-5"/>
              <rect x="12" y="2" width="10" height="20" rx="2" opacity="0.3"/>
            </svg>
          </div>
          <h4 class="research-tech-title">数据智能架构</h4>
          <p class="research-tech-subtitle">Data Intelligence</p>
          <ul class="research-tech-list">
            <li class="research-tech-item">
              <svg class="check-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
              <span>多源异构数据融合</span>
            </li>
            <li class="research-tech-item">
              <svg class="check-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
              <span>实时流处理引擎</span>
            </li>
            <li class="research-tech-item">
              <svg class="check-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
              <span>统一数据建模</span>
            </li>
          </ul>
        </div>

        <!-- AI算法引擎 -->
        <div class="research-tech-card fade-in stagger-2">
          <div class="research-tech-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="11" width="18" height="10" rx="2"/>
              <circle cx="12" cy="5" r="2"/>
              <path d="M12 7v4"/>
              <line x1="8" y1="16" x2="8" y2="16"/>
              <line x1="16" y1="16" x2="16" y2="16"/>
            </svg>
          </div>
          <h4 class="research-tech-title">AI算法引擎</h4>
          <p class="research-tech-subtitle">AI Engine</p>
          <ul class="research-tech-list">
            <li class="research-tech-item">
              <svg class="check-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
              <span>机器学习模型库</span>
            </li>
            <li class="research-tech-item">
              <svg class="check-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
              <span>图计算与关系分析</span>
            </li>
            <li class="research-tech-item">
              <svg class="check-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
              <span>智能决策系统</span>
            </li>
          </ul>
        </div>

        <!-- 云原生平台 -->
        <div class="research-tech-card fade-in stagger-3">
          <div class="research-tech-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M17.5 19c0-1.7-1.3-3-3-3h-11c-1.7 0-3 1.3-3 3"/>
              <path d="M19 16c1.7 0 3-1.3 3-3c0-1.4-.9-2.6-2.2-2.9"/>
              <path d="M21 10c0-1.7-1.3-3-3-3"/>
              <path d="M7 10c0-1.7 1.3-3 3-3"/>
              <path d="M12 3c-2.5 0-4.5 2-4.5 4.5"/>
            </svg>
          </div>
          <h4 class="research-tech-title">云原生平台</h4>
          <p class="research-tech-subtitle">Cloud Native</p>
          <ul class="research-tech-list">
            <li class="research-tech-item">
              <svg class="check-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
              <span>微服务架构设计</span>
            </li>
            <li class="research-tech-item">
              <svg class="check-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
              <span>容器化部署运维</span>
            </li>
            <li class="research-tech-item">
              <svg class="check-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
              <span>DevOps持续交付</span>
            </li>
          </ul>
        </div>

        <!-- 安全合规体系 -->
        <div class="research-tech-card fade-in stagger-4">
          <div class="research-tech-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              <path d="M9 12l2 2 4-4"/>
            </svg>
          </div>
          <h4 class="research-tech-title">安全合规体系</h4>
          <p class="research-tech-subtitle">Security & Compliance</p>
          <ul class="research-tech-list">
            <li class="research-tech-item">
              <svg class="check-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
              <span>等保2.0三级认证</span>
            </li>
            <li class="research-tech-item">
              <svg class="check-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
              <span>全链路数据加密</span>
            </li>
            <li class="research-tech-item">
              <svg class="check-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
              <span>智能风控体系</span>
            </li>
          </ul>
        </div>
      </div>
    </div>

    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <!-- 三、研发团队（人才实力展示） -->
    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <div class="research-team">
      <div class="research-section-header fade-in">
        <div class="research-section-title-wrapper">
          <div class="research-section-indicator"></div>
          <h3 class="research-section-title">研发团队</h3>
          <span class="research-section-subtitle">R&D Team</span>
        </div>
        <div class="research-team-stats">
          <span>研发人员占比 <strong>85%</strong></span>
          <span>硕博学历 <strong>30%</strong></span>
          <span>年均产出专利 <strong>20+</strong></span>
        </div>
      </div>

      <div class="research-team-grid">
        <!-- 首席架构师 -->
        <div class="research-team-card fade-in stagger-1">
          <div>
            <img src="https://modao.cc/agent-py/media/generated_images/2026-04-08/8c6c4653fc8344c18be1b31c38506dab.jpg"
                 alt="首席架构师"
                 class="research-team-avatar">
            <div class="team-overlay">
              <p class="research-team-overlay-text">20年+金融系统架构经验</p>
              <p class="research-team-overlay-text">主导过多个大型分布式系统设计</p>
            </div>
          </div>
          <h5 class="research-team-name">张明远</h5>
          <p class="research-team-role">首席架构师</p>
        </div>

        <!-- 算法专家1 -->
        <div class="research-team-card fade-in stagger-2">
          <div>
            <img src="https://modao.cc/agent-py/media/generated_images/2026-04-08/9436339574264450ad07990fecf84856.jpg"
                 alt="算法专家"
                 class="research-team-avatar">
            <div class="team-overlay">
              <p class="research-team-overlay-text">AI方向专家</p>
              <p class="research-team-overlay-text">深度学习模型研发</p>
            </div>
          </div>
          <h5 class="research-team-name">李华</h5>
          <p class="research-team-role">算法专家</p>
        </div>

        <!-- 算法专家2 -->
        <div class="research-team-card fade-in stagger-3">
          <div>
            <img src="https://modao.cc/agent-py/media/generated_images/2026-04-08/e746c839b9f240c1a6aff895c0e77eeb.jpg"
                 alt="大数据专家"
                 class="research-team-avatar">
            <div class="team-overlay">
              <p class="research-team-overlay-text">大数据方向专家</p>
              <p class="research-team-overlay-text">数据挖掘与分析</p>
            </div>
          </div>
          <h5 class="research-team-name">王芳</h5>
          <p class="research-team-role">大数据专家</p>
        </div>

        <!-- 产品负责人 -->
        <div class="research-team-card fade-in stagger-4">
          <div>
            <img src="https://modao.cc/agent-py/media/generated_images/2026-04-08/1444242ae2a24c279fff474d261da6f7.jpg"
                 alt="产品负责人"
                 class="research-team-avatar">
            <div class="team-overlay">
              <p class="research-team-overlay-text">产品矩阵负责人</p>
              <p class="research-team-overlay-text">反洗钱/运维/标讯产品</p>
            </div>
          </div>
          <h5 class="research-team-name">陈思</h5>
          <p class="research-team-role">产品负责人</p>
        </div>
      </div>

      <!-- 合作高校标签 -->
      <div class="research-partners fade-in">
        <span class="research-partners-label">合作院校：</span>
        <span class="research-partner-tag">清华大学</span>
        <span class="research-partner-tag">上海交通大学</span>
        <span class="research-partner-tag">浙江大学</span>
        <span class="research-partner-tag">复旦大学</span>
        <span class="research-partner-tag">中国科学技术大学</span>
      </div>
    </div>

    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <!-- 四、专利与资质（荣誉背书） -->
    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <div class="research-patents">
      <div class="research-patents-layout">
        <!-- 左侧数据 -->
        <div class="research-patents-data fade-in">
          <div class="research-patents-data-title">
            <div class="research-patents-main-number">110+</div>
            <p class="research-patents-main-title">软件著作权</p>
            <p class="research-patents-main-subtitle">Software Copyrights</p>
          </div>
          <div class="research-patents-stats-grid">
            <div class="research-patents-stat-card glass-morphism">
              <div class="research-patents-stat-number">120+</div>
              <p class="research-patents-stat-label">核心专利</p>
            </div>
            <div class="research-patents-stat-card glass-morphism">
              <div class="research-patents-stat-number">45+</div>
              <p class="research-patents-stat-label">发明专利</p>
            </div>
            <div class="research-patents-stat-card glass-morphism">
              <div class="research-patents-stat-number">5+</div>
              <p class="research-patents-stat-label">国际专利</p>
            </div>
          </div>
        </div>

        <!-- 右侧证书墙 -->
        <div class="research-patents-wall fade-in">
          <div class="research-patents-grid">
            <div class="research-patent-item">
              <div class="patent-content">
                <svg class="patent-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                </svg>
              </div>
              <div class="patent-overlay"><span>ISO27001认证</span></div>
            </div>
            <div class="research-patent-item">
              <div class="patent-content">
                <svg class="patent-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                </svg>
              </div>
              <div class="patent-overlay"><span>CMMI5认证</span></div>
            </div>
            <div class="research-patent-item">
              <div class="patent-content">
                <svg class="patent-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                </svg>
              </div>
              <div class="patent-overlay"><span>国家高新技术企业</span></div>
            </div>
            <div class="research-patent-item">
              <div class="patent-content">
                <svg class="patent-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                </svg>
              </div>
              <div class="patent-overlay"><span>CNAS实验室</span></div>
            </div>
            <div class="research-patent-item">
              <div class="patent-content">
                <svg class="patent-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                </svg>
              </div>
              <div class="patent-overlay"><span>软件企业认定</span></div>
            </div>
            <div class="research-patent-item">
              <div class="patent-content">
                <svg class="patent-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                </svg>
              </div>
              <div class="patent-overlay"><span>信息安全认证</span></div>
            </div>
            <div class="research-patent-item">
              <div class="patent-content">
                <svg class="patent-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                </svg>
              </div>
              <div class="patent-overlay"><span>ITSS认证</span></div>
            </div>
            <div class="research-patent-item">
              <div class="patent-content">
                <svg class="patent-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                </svg>
              </div>
              <div class="patent-overlay"><span>系统集成资质</span></div>
            </div>
          </div>
        </div>
      </div>

      <!-- 底部资质标签行 -->
      <div class="research-patents-tags fade-in">
        <span class="research-patents-tag">ISO27001</span>
        <span class="research-patents-tag">CMMI5</span>
        <span class="research-patents-tag">国家高新技术企业</span>
        <span class="research-patents-tag">CNAS实验室</span>
        <span class="research-patents-tag">软件企业认定</span>
        <span class="research-patents-tag">信息安全等级保护</span>
      </div>
    </div>

    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <!-- 五、研发成果（核心亮点：产品研发历程） -->
    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <div class="research-achievements">
      <div class="research-achievements-container">

        <!-- 标题区 -->
        <div class="research-achievements-title-row">
          <div>
            <h2 class="research-achievements-title">昆仑时代研发中心</h2>
            <p class="research-achievements-subtitle">KUNLUN R&D CENTER · 持续探索技术边界，驱动产业智能升级</p>
          </div>
