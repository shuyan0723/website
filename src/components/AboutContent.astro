<script>
// 主营业务与服务 Swiper 轮播初始化
import Swiper from 'swiper';
import { Pagination, Autoplay } from 'swiper/modules';
import 'swiper/css';
import 'swiper/css/pagination';

// 等待 DOM 加载完成
function initServicesSwiper() {
  const servicesSwiper = new Swiper('.services-swiper', {
    modules: [Pagination, Autoplay],
    slidesPerView: 3,
    spaceBetween: 20,
    loop: true,
    autoplay: {
      delay: 3000,
      disableOnInteraction: false,
      pauseOnMouseEnter: true,
    },
    pagination: {
      el: '.swiper-pagination',
      clickable: true,
    },
    breakpoints: {
      320: {
        slidesPerView: 1,
        spaceBetween: 10,
      },
      768: {
        slidesPerView: 2,
        spaceBetween: 15,
      },
      1024: {
        slidesPerView: 3,
        spaceBetween: 20,
      },
    },
  });

  // 确保自动播放启动
  if (servicesSwiper.autoplay) {
    servicesSwiper.autoplay.start();
  }

  // 鼠标移入暂停，移出继续
  const swiperContainer = document.querySelector('.services-swiper');
  if (swiperContainer && servicesSwiper.autoplay) {
    swiperContainer.addEventListener('mouseenter', () => {
      servicesSwiper.autoplay.stop();
    });
    swiperContainer.addEventListener('mouseleave', () => {
      servicesSwiper.autoplay.start();
    });
  }
}

// 页面加载完成后初始化
if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', initServicesSwiper);
} else {
  initServicesSwiper();
}


// ========== 叙事型曲线时间轴功能 ==========
function initNarrativeTimeline() {
  const wrapper = document.querySelector('.narrative-timeline-wrapper') as HTMLElement;
  const nodes = document.querySelectorAll('.timeline-node');
  const prevBtn = document.getElementById('curvePrev') as HTMLButtonElement | null;
  const nextBtn = document.getElementById('curveNext') as HTMLButtonElement | null;
  const paginationItems = document.querySelectorAll('.pagination-item');

  if (!wrapper || nodes.length === 0) return;

  // 每页的数据内容
  const pageData = [
    // 第1页 - 起步期 (2020-2022)
    [
      { year: '2020', text: '昆仑时代（上海）系统集成有限公司正式成立，注册资金1亿元人民币，开启数字化服务新征程。' },
      { year: '2021', text: '业务覆盖智能穿戴、汽车电子、金融科技等多个领域，员工规模突破1000人。' },
      { year: '2022', text: '在北京、深圳、成都、杭州等地设立分公司，形成覆盖全国主要城市的服务网络。' }
    ],
    // 第2页 - 发展期 (2023-2025)
    [
      { year: '2023', text: '进军海外市场，在新加坡、美国、马来西亚等地设立分支机构，开启全球化战略。' },
      { year: '2024', text: '员工规模近3000人，服务全球25个地区，成为行业领先的IT服务及数字化运营专家。' },
      { year: '2025', text: '发布自主研发的"昆仑智能大脑"AI平台，在金融反洗钱、智能运维等领域实现技术突破，服务客户突破5000家。' }
    ],
    // 第3页 - 腾飞期 (2026-2027)
    [
      { year: '2026', text: '正式启动上市计划，在欧洲、东南亚等15个国家和地区拓展业务，构建覆盖全球40+地区的数字化服务生态体系。' },
      { year: '2027', text: '持续引领行业发展，深化AI技术应用，为全球客户提供更优质的数字化服务，实现可持续增长。' },
      { year: '展望', text: '以技术创新为驱动，以客户价值为导向，致力于成为全球领先的数字化转型服务提供商。' }
    ]
  ];

  // 状态管理
  let currentPage = 0;
  const totalPages = 3;

  // 更新节点内容
  function updateNodeContent() {
    const data = pageData[currentPage];

    nodes.forEach((node: Element, index: number) => {
      if (index < data.length) {
        const yearEl = node.querySelector('.node-year') as HTMLElement;
        const textEl = node.querySelector('.node-text') as HTMLElement;

        if (yearEl) yearEl.textContent = data[index].year;
        if (textEl) textEl.textContent = data[index].text;

        // 添加淡入动画效果
        node.classList.remove('fade-in');
        void node.offsetWidth; // 触发重排
        node.classList.add('fade-in');
      }
    });

    // 更新分页指示器
    paginationItems.forEach((item: Element, index: number) => {
      if (index === currentPage) {
        item.classList.add('active');
      } else {
        item.classList.remove('active');
      }
    });
  }

  // 切换页面
  function goToPage(pageIndex: number) {
    if (pageIndex >= 0 && pageIndex < totalPages && pageIndex !== currentPage) {
      currentPage = pageIndex;
      updateNodeContent();
    }
  }

  // 事件监听
  prevBtn?.addEventListener('click', () => {
    if (currentPage > 0) goToPage(currentPage - 1);
  });

  nextBtn?.addEventListener('click', () => {
    if (currentPage < totalPages - 1) goToPage(currentPage + 1);
  });

  paginationItems.forEach((item: Element, index: number) => {
    item.addEventListener('click', () => {
      goToPage(index);
    });
  });

  // 节点悬停效果
  nodes.forEach((node: Element) => {
    node.addEventListener('mouseenter', () => {
      (node as HTMLElement).classList.add('hover');
    });
    node.addEventListener('mouseleave', () => {
      (node as HTMLElement).classList.remove('hover');
    });
  });

  // 初始化
  updateNodeContent();
}

// 延迟初始化
setTimeout(() => {
  initNarrativeTimeline();
}, 500);
</script>

