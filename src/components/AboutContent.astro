<script>
// 主营业务与服务 Swiper 轮播初始化
import Swiper from 'swiper';
import { Pagination, Autoplay } from 'swiper/modules';
import 'swiper/css';
import 'swiper/css/pagination';

// 等待 DOM 加载完成
function initServicesSwiper() {
  const servicesSwiper = new Swiper('.services-swiper', {
    modules: [Pagination, Autoplay],
    slidesPerView: 3,
    spaceBetween: 20,
    loop: true,
    autoplay: {
      delay: 3000,
      disableOnInteraction: false,
      pauseOnMouseEnter: true,
    },
    pagination: {
      el: '.swiper-pagination',
      clickable: true,
    },
    breakpoints: {
      320: {
        slidesPerView: 1,
        spaceBetween: 10,
      },
      768: {
        slidesPerView: 2,
        spaceBetween: 15,
      },
      1024: {
        slidesPerView: 3,
        spaceBetween: 20,
      },
    },
  });

  // 确保自动播放启动
  if (servicesSwiper.autoplay) {
    servicesSwiper.autoplay.start();
  }

  // 鼠标移入暂停，移出继续
  const swiperContainer = document.querySelector('.services-swiper');
  if (swiperContainer && servicesSwiper.autoplay) {
    swiperContainer.addEventListener('mouseenter', () => {
      servicesSwiper.autoplay.stop();
    });
    swiperContainer.addEventListener('mouseleave', () => {
      servicesSwiper.autoplay.start();
    });
  }
}

// 页面加载完成后初始化
if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', initServicesSwiper);
} else {
  initServicesSwiper();
}

// 发展历程轮播功能
const items = document.querySelectorAll('.timeline-item');
const dots = document.querySelectorAll('.timeline-dot');
const prevBtn = document.getElementById('timelinePrev') as HTMLButtonElement | null;
const nextBtn = document.getElementById('timelineNext') as HTMLButtonElement | null;
let currentIndex = 0;
const total = items.length;

// 更新轮播状态
function updateCarousel() {
  // 重置所有节点状态
  items.forEach((item, index) => {
    item.classList.toggle('active', index === currentIndex);
  });
  dots.forEach((dot, index) => {
    dot.classList.toggle('active', index === currentIndex);
  });

  // 按钮状态控制
  if (prevBtn) prevBtn.disabled = currentIndex === 0;
  if (nextBtn) nextBtn.disabled = currentIndex === total - 1;
}

// 按钮事件绑定
prevBtn?.addEventListener('click', () => {
  if (currentIndex > 0) {
    currentIndex--;
    updateCarousel();
  }
});

nextBtn?.addEventListener('click', () => {
  if (currentIndex < total - 1) {
    currentIndex++;
    updateCarousel();
  }
});

// 初始化
updateCarousel();
</script>

